# ── Maven build output ────────────────────────────────────────────────────────
target/
**/target/

# Maven Shade plugin generates this alongside the shaded JAR
dependency-reduced-pom.xml
**/dependency-reduced-pom.xml

# ── AWS CDK ───────────────────────────────────────────────────────────────────
# Synthesised CloudFormation templates, staged Lambda JARs, and manifests.
# Always regenerated by `cdk synth` / `cdk deploy` — never commit.
infrastructure/cdk.out/

# ── Java compiled output ──────────────────────────────────────────────────────
*.class
*.jar
# Exception: allow the parent/module POM JARs if ever published (uncommon here)
!*-sources.jar

# ── IDE — IntelliJ IDEA ───────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/

# ── IDE — VS Code ─────────────────────────────────────────────────────────────
.vscode/

# ── IDE — Eclipse ─────────────────────────────────────────────────────────────
.classpath
.project
.settings/
.factorypath

# ── OS generated files ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Environment / secrets ─────────────────────────────────────────────────────
# Never commit real secrets — JWT_SECRET and AWS credentials must stay local.
.env
.env.*
*.pem
*.key
